[Unit]
Description=Front End Message Server
After=network.target

[Service]
User=server
Group=server
SyslogIdentifier=frontend-msg
WorkingDirectory=/srv/server/chub-archive-server/backend
ExecStart=/srv/server/venv/bin/gunicorn --workers 3 --bind 0.0.0.0:5002 frontend-msg:app --access-logfile '-' --error-logfile '-'
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target

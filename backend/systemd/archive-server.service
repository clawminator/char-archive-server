[Unit]
Description=Character Archive Server
After=network.target

[Service]
User=server
Group=server
SyslogIdentifier=archive-server
WorkingDirectory=/srv/server/chub-archive-server/backend
ExecStart=/srv/server/venv/bin/gunicorn --workers 7 --bind 0.0.0.0:5500 server:app --access-logfile '-' --error-logfile '-'
Restart=always
RestartSec=5
LimitNOFILE=30000

[Install]
WantedBy=multi-user.target
